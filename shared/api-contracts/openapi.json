{
  "openapi": "3.0.3",
  "info": {
    "title": "FelloWay API — Common components",
    "version": "0.1.0",
    "description": "Shared schemas and error envelope for all domains."
  },
  "tags": [
    {
      "name": "openapi_other",
      "x-displayName": "other"
    }
  ],
  "paths": {
    "/auth/oauth/{provider}/token": {
      "post": {
        "summary": "Exchange OAuth authorization code for API tokens",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "linkedin",
                "facebook"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "code",
                  "redirectUri",
                  "codeVerifier"
                ],
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "redirectUri": {
                    "type": "string"
                  },
                  "codeVerifier": {
                    "type": "string",
                    "description": "PKCE verifier from mobile client"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "Refresh access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "refreshToken"
                ],
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New token pair",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Revoke refresh token",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Revoked"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/chat/stream-token": {
      "get": {
        "summary": "GetStream user token for mobile SDK",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Stream JWT",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "token"
                  ],
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/users/me": {
      "get": {
        "summary": "Current user profile",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      },
      "put": {
        "summary": "Update current user profile",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserProfileUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/users/me/avatar": {
      "post": {
        "summary": "Upload avatar (multipart)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "avatarUrl": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/users/me/push-preferences": {
      "put": {
        "summary": "Update notification toggles",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushPreferences"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/users/{id}/reviews": {
      "get": {
        "summary": "List reviews for a user",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Review"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/users/{id}/block": {
      "post": {
        "summary": "Block a user",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Blocked"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events": {
      "get": {
        "summary": "List events (paginated, filterable)",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "interest",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListPage"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events/{id}": {
      "get": {
        "summary": "Event detail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events/{id}/attend": {
      "post": {
        "summary": "Join event",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "204": {
            "description": "Joined"
          }
        },
        "tags": [
          "openapi_other"
        ]
      },
      "delete": {
        "summary": "Leave event",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "204": {
            "description": "Left"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events/{id}/attendees": {
      "get": {
        "summary": "List attendees (subscribers only)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Attendee"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events/{id}/trips": {
      "get": {
        "summary": "List trip chats for event",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Trip"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      },
      "post": {
        "summary": "Create trip chat",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TripCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Trip"
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/trips/{id}/join": {
      "post": {
        "summary": "Request to join trip",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TripId"
          }
        ],
        "responses": {
          "201": {
            "description": "Request created"
          }
        },
        "tags": [
          "openapi_other"
        ]
      },
      "delete": {
        "summary": "Cancel pending join request",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TripId"
          }
        ],
        "responses": {
          "204": {
            "description": "Cancelled"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/trips/{id}/join-requests": {
      "get": {
        "summary": "Pending join requests (trip owner)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TripId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TripJoinRequest"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/trips/{id}/approve/{userId}": {
      "post": {
        "summary": "Approve join request",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TripId"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Approved"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    },
    "/events/{id}/attendees/{userId}/review": {
      "post": {
        "summary": "Post-event review",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EventId"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "rating"
                ],
                "properties": {
                  "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "tags": [
          "openapi_other"
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "validation_failed"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      },
      "FieldError": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "CursorPageMeta": {
        "type": "object",
        "properties": {
          "nextCursor": {
            "type": "string",
            "nullable": true
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "Uuid": {
        "type": "string",
        "format": "uuid"
      },
      "DateTimeUtc": {
        "type": "string",
        "format": "date-time"
      },
      "TokenResponse": {
        "type": "object",
        "required": [
          "accessToken",
          "expiresIn",
          "refreshToken"
        ],
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "expiresIn": {
            "type": "integer"
          },
          "refreshToken": {
            "type": "string"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "homeCity": {
            "type": "string"
          },
          "interestIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "avatarUrl": {
            "type": "string"
          },
          "aggregateRating": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "UserProfileUpdate": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "homeCityId": {
            "type": "string",
            "format": "uuid"
          },
          "interestIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "PushPreferences": {
        "type": "object",
        "properties": {
          "globalEnabled": {
            "type": "boolean"
          },
          "eventMessages": {
            "type": "boolean"
          },
          "tripMessages": {
            "type": "boolean"
          },
          "directMessages": {
            "type": "boolean"
          }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "authorId": {
            "type": "string",
            "format": "uuid"
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "comment": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EventListPage": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "startsAt": {
            "type": "string",
            "format": "date-time"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time"
          },
          "city": {
            "type": "string"
          },
          "coverImageUrl": {
            "type": "string"
          },
          "attendeeCount": {
            "type": "integer"
          },
          "isJoined": {
            "type": "boolean"
          }
        }
      },
      "Attendee": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "homeCity": {
            "type": "string"
          }
        }
      },
      "Trip": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "routeLabel": {
            "type": "string"
          },
          "departureAt": {
            "type": "string",
            "format": "date-time"
          },
          "roleType": {
            "type": "string"
          },
          "memberCount": {
            "type": "integer"
          }
        }
      },
      "TripCreate": {
        "type": "object",
        "required": [
          "routeLabel",
          "departureAt",
          "roleType",
          "originCityId"
        ],
        "properties": {
          "routeLabel": {
            "type": "string"
          },
          "departureAt": {
            "type": "string",
            "format": "date-time"
          },
          "roleType": {
            "type": "string"
          },
          "originCityId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TripJoinRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "requesterId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "rejected",
              "cancelled"
            ]
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated but not allowed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "EventId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "TripId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    }
  }
}