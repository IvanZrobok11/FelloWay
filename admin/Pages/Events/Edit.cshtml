@page "{id:guid}"
@model FelloWay.Admin.Pages.Events.EditModel
@{
    ViewData["Title"] = "Edit event";
}

<div class="card">
    <h1>Edit event</h1>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error">@Model.ErrorMessage</p>
    }
    <form method="post" enctype="multipart/form-data">
        <partial name="_EventFormFields" model="Model.Input" />
        <div class="form-group">
            <label asp-for="Input.Status">Status</label>
            <select asp-for="Input.Status">
                <option value="active">active</option>
                <option value="rejected">rejected (unpublish)</option>
                <option value="pending">pending</option>
                <option value="archived">archived</option>
            </select>
        </div>
        @if (!string.IsNullOrEmpty(Model.CurrentCoverUrl))
        {
            <p>Current cover: <a href="@Model.CurrentCoverUrl" target="_blank" rel="noopener">@Model.CurrentCoverUrl</a></p>
        }
        <div class="form-group">
            <label asp-for="Input.CoverFile">Replace cover image</label>
            <input asp-for="Input.CoverFile" type="file" accept="image/*" />
        </div>
        <button type="submit">Save</button>
        <a asp-page="Index">Cancel</a>
    </form>
</div>
