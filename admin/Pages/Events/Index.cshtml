@page
@model FelloWay.Admin.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

<div class="card">
    <h1>Events</h1>
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <p class="success">@Model.StatusMessage</p>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error">@Model.ErrorMessage</p>
    }
    <p><a class="btn" asp-page="Create">Create event</a></p>
    @if (Model.Events.Count == 0)
    {
        <p>No events yet.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Starts</th>
                    <th>City</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Events)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.StartsAt.ToString("g")</td>
                        <td>@item.CityName</td>
                        <td>@item.Status</td>
                        <td><a asp-page="Edit" asp-route-id="@item.Id">Edit</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
