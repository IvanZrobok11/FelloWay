@page
@model FelloWay.Admin.Pages.Events.CreateModel
@{
    ViewData["Title"] = "Create event";
}

<div class="card">
    <h1>Create event</h1>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error">@Model.ErrorMessage</p>
    }
    <div asp-validation-summary="All" class="error"></div>
    <form method="post" enctype="multipart/form-data">
        <partial name="_EventFormFields" for="Input" />
        <div class="form-group">
            <label asp-for="Input.CoverFile">Cover image</label>
            <input asp-for="Input.CoverFile" type="file" accept="image/*" />
        </div>
        <button type="submit">Create</button>
    </form>
</div>
