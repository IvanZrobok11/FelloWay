@page
@model FelloWay.Admin.Pages.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="card" style="max-width: 420px; margin: 0 auto;">
    <h1>Sign in</h1>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error" role="alert">@Model.ErrorMessage</p>
    }
    <form method="post">
        <div class="form-group">
            <label asp-for="Input.Username">Username</label>
            <input asp-for="Input.Username" autocomplete="username" />
        </div>
        <div class="form-group">
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        </div>
        <button type="submit">Sign in</button>
    </form>
</div>
