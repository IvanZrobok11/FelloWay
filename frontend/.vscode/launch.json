{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "felloway (Chrome, BFF HTTPS)",
      "cwd": "${workspaceFolder}",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--web-port=7357",
        "--dart-define=API_MODE=live",
        "--dart-define=API_BASE_URL=https://localhost:7086",
        "--dart-define=STREAM_API_KEY=${env:STREAM_API_KEY}"
      ]
    },
    {
      "name": "felloway (Chrome, dev backend only)",
      "cwd": "${workspaceFolder}",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--web-port=7357",
        "--dart-define=API_MODE=live",
        "--dart-define=API_BASE_URL=https://localhost:7086",
        "--dart-define=STREAM_API_KEY=${env:STREAM_API_KEY}"
      ]
    }
  ]
}
