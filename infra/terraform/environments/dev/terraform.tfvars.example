# Technical URLs (no domain registration). After apply: terraform output api_url web_url
use_custom_domain = false

vpc_cidr          = "10.10.0.0/16"
db_instance_class = "db.t4g.micro"
jwt_signing_key        = "change-me-min-32-characters-for-jwt-signing!!"
linkedin_client_id     = "your-linkedin-client-id"
linkedin_client_secret = "your-linkedin-client-secret"
stream_api_key         = "your-getstream-api-key"
stream_api_secret      = "your-getstream-api-secret"
# GitHub variable DEV_STREAM_API_KEY must match stream_api_key (Flutter build).
# LinkedIn redirect URL (after apply): https://<terraform output api_url>/auth/linkedin/callback

# Custom domain (set use_custom_domain = true and fill these):
# domain_name       = "felloway.click"
# api_host          = "dev.api.felloway.click"
# web_host          = "dev.app.felloway.click"

# After bootstrap, configure backend.tf with:
# bucket = "your-state-bucket"
# region = "eu-central-1"
